{
  "name": "vector-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/modules/ai/prompts && cp src/modules/ai/prompts/goalDiscovery.protocol.json dist/modules/ai/prompts/goalDiscovery.protocol.json",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "11.0.1",
    "@fastify/rate-limit": "10.2.1",
    "fastify": "5.10.0",
    "pino": "9.7.0",
    "zod": "3.24.3"
  },
  "devDependencies": {
    "@types/node": "22.15.2",
    "tsx": "4.19.3",
    "typescript": "5.8.3",
    "vitest": "3.2.7"
  }
}
