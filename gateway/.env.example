NODE_ENV=development
HOST=127.0.0.1
PORT=8787
PUBLIC_WEB_ORIGIN=http://localhost:3000
POCKETBASE_URL=http://127.0.0.1:8090
BRAIN_DUMP_MAX_TEXT_LENGTH=20000
VOICE_MAX_BYTES=15000000
VOICE_MAX_DURATION_SECONDS=180
VOICE_TRANSCRIPTION_TIMEOUT_MS=20000
GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_MS=20000
# GEMINI_API_KEY=server-only-key
TRUST_PROXY=false

# Integration flags are off until their routes are implemented.
ENABLE_GOOGLE_INTEGRATION=false
ENABLE_TELEGRAM_INTEGRATION=false
ENABLE_STRIPE_INTEGRATION=false

# Set these only when the corresponding integration flag is true.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://api.example.com/api/v1/integrations/google-calendar/callback
# GOOGLE_TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-server-key
# TELEGRAM_BOT_TOKEN=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
