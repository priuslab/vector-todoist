# Copy to deploy/.env on the host. Do not commit deploy/.env.
NODE_ENV=production
PUBLIC_WEB_ORIGIN=https://app.example.com
BRAIN_DUMP_MAX_TEXT_LENGTH=20000
VOICE_MAX_BYTES=15000000
VOICE_MAX_DURATION_SECONDS=180
VOICE_TRANSCRIPTION_TIMEOUT_MS=20000

# Required by the production Gateway. Keep this server-side only; never use a
# VITE_ variable or commit the real value.
GEMINI_API_KEY=replace-with-server-side-gemini-key
GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_MS=20000

# Host-only bindings consumed by the existing system Caddy.
GATEWAY_HOST_PORT=8787
POCKETBASE_HOST_PORT=8090

# Keep integrations disabled until their routes and credentials are configured.
ENABLE_GOOGLE_INTEGRATION=false
ENABLE_TELEGRAM_INTEGRATION=false
ENABLE_STRIPE_INTEGRATION=false

# Set only when the corresponding integration flag is true. These are examples,
# not credentials; keep real values in deploy/.env or your host secret store.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# TELEGRAM_BOT_TOKEN=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
